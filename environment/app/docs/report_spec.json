{
  "title": "Settlement Rollup — Diagnosis & Report Spec",
  "version": "3.3",
  "cli": {
    "path": "/app/log_audit.py",
    "subcommands": {
      "diagnose": {
        "usage": "python3 /app/log_audit.py diagnose --dossier PATH --report PATH",
        "defaults": {
          "dossier": "/app/incident/export_dossier.md",
          "report": "/app/output/diagnosis.json"
        },
        "must_include_all_allowed_ids": true,
        "must_not_include_repaired_keys": ["verified_summary", "output_paths"],
        "input_events_path": "/app/data/events.json"
      },
      "repair": {
        "usage": "python3 /app/log_audit.py repair --output-dir PATH",
        "defaults": {
          "output_dir": "/app/output"
        }
      }
    }
  },
  "diagnosis_report": {
    "required_keys_diagnosed": ["pipeline_status", "issues_found", "input_stats"],
    "required_keys_repaired": [
      "pipeline_status",
      "issues_found",
      "input_stats",
      "verified_summary",
      "output_paths"
    ],
    "pipeline_status_diagnosed": "diagnosed",
    "pipeline_status_repaired": "repaired",
    "issues_found_item": {
      "required_fields": ["id", "severity", "description", "resolution", "evidence"],
      "allowed_ids": [
        "wrong_posted_field",
        "priority_filter",
        "recency_order",
        "priority_normalization",
        "dedupe_transaction",
        "waived_filter"
      ],
      "evidence": {
        "required_fields": ["dossier_quote", "pipeline_evidence", "repair_action"],
        "pipeline_evidence_source": "/app/workflow/.export_report.original",
        "pipeline_evidence_format": "literal substring excerpt from frozen original workflow source",
        "dossier_quote_format": "verbatim excerpt from /app/incident/export_dossier.md (whitespace-normalized match)",
        "term_matching": "case-sensitive substring match for all required_terms_by_issue entries",
        "required_terms_by_issue": {
          "wrong_posted_field": {
            "dossier_quote": ["posted_at", "posted_ms"],
            "pipeline_evidence": ["event[\"posted_at\"]"],
            "repair_action": ["posted_ms"]
          },
          "priority_filter": {
            "dossier_quote": ["risk", "critical"],
            "pipeline_evidence": ["priority == \"critical\""],
            "repair_action": ["risk"]
          },
          "recency_order": {
            "dossier_quote": ["ascending", "descending"],
            "pipeline_evidence": ["sort", "posted_ms"],
            "repair_action": ["reverse=True"]
          },
          "priority_normalization": {
            "dossier_quote": ["RISK", "lowercase"],
            "pipeline_evidence": ["priority"],
            "repair_action": [".lower("]
          },
          "dedupe_transaction": {
            "dossier_quote": ["duplicate", "posted_ms"],
            "pipeline_evidence": ["for event in events"],
            "repair_action": ["dedupe"]
          },
          "waived_filter": {
            "dossier_quote": ["waived", "excluded"],
            "pipeline_evidence": ["escalations.append"],
            "repair_action": ["waived"]
          }
        }
      }
    },
    "input_stats": {
      "required_fields": ["record_count", "unique_txn_ids", "merchants"],
      "merchants_sort": "ascending alphabetical",
      "source_events_path": "/app/data/events.json"
    },
    "verified_summary": {
      "required_fields": [
        "schema_version",
        "raw_record_count",
        "unique_txn_ids",
        "total_records",
        "priority_counts",
        "merchants",
        "escalated_count",
        "waived_excluded_count"
      ]
    },
    "output_paths": {
      "summary_json": "<output-dir>/summary.json",
      "flagged_jsonl": "<output-dir>/flagged.jsonl",
      "service_matrix_json": "<output-dir>/service_matrix.json"
    }
  },
  "canonicalization": {
    "dedupe_by_txn_id": "collapse duplicate txn_id rows, keeping the row with the highest posted_ms; if posted_ms ties, choose higher priority rank (critical > risk > info > debug); if still tied, prefer waived=false over waived=true; if still tied, choose lexicographically larger normalized note, then lexicographically larger normalized merchant",
    "posted_ms_normalization": "coerce posted_ms to int (trim string whitespace before int conversion; invalid values become 0)",
    "note_normalization": "normalize notes by collapsing internal whitespace to single spaces before tie-breaks and output",
    "priority_normalization": "strip surrounding whitespace then lowercase priority strings before counting and escalation",
    "merchant_normalization": "strip surrounding whitespace then lowercase merchant names before grouping",
    "waived_normalization": "treat boolean-like strings ('true','1','yes') as true",
    "total_records": "count canonical deduped records (waived rows remain in totals)",
    "flagged_export": "include risk and critical only, exclude waived=true, sort by posted_ms descending then priority rank descending then txn_id ascending"
  },
  "repair_audit": {
    "required_keys": [
      "patched_workflow",
      "processing_steps",
      "removed_tokens",
      "pre_repair",
      "post_repair"
    ],
    "processing_steps": [
      "normalize_posted_ms",
      "normalize_priority",
      "dedupe_txn_id",
      "filter_waived",
      "build_escalations"
    ],
    "patched_workflow": "/app/workflow/export_report.py",
    "forbidden_executable_tokens": [
      "event[\"posted_at\"]",
      "priority == \"critical\""
    ],
    "removed_tokens_schema": {
      "description": "Map each forbidden_executable_tokens entry to a boolean (true when absent from patched executable code, excluding comments and docstrings)."
    },
    "pre_repair": {
      "required_fields": ["pipeline_source_sha256", "pipeline_tokens_present"],
      "capture_order": "before any write to export_report.py",
      "pipeline_tokens_present_schema": {
        "description": "Map each forbidden_executable_tokens entry to a boolean (true when present in frozen broken snapshot before repair)."
      }
    },
    "post_repair": {
      "required_fields": ["escalated_count", "rerun_escalated_count"]
    }
  },
  "workflow_repair": {
    "path": "/app/workflow/export_report.py",
    "cli_usage": "python3 /app/workflow/export_report.py --input PATH --output-dir PATH",
    "defaults": {
      "input": "/app/data/events.json",
      "output_dir": "/app/output"
    },
    "forbidden_executable_tokens": [
      "event[\"posted_at\"]",
      "priority == \"critical\""
    ],
    "required_executable_tokens": [
      "int(",
      ".lower(",
      "reverse=True",
      ".strip(",
      "\"yes\""
    ],
    "token_check_scope": "executable code only (exclude comments and docstrings)"
  },
  "outputs": {
    "summary_json": {
      "schema_version": "settlement-rollup-v2",
      "priority_counts_key_order": ["critical", "debug", "info", "risk"]
    },
    "service_matrix_json": {
      "description": "Flat map of merchant -> per-priority counts from canonical deduped records.",
      "shape": {
        "<merchant>": {
          "critical": 0,
          "debug": 0,
          "info": 0,
          "risk": 0
        }
      },
      "notes": "Top-level keys are merchant names only. Do not wrap counts in schema_version, merchants, or metadata objects.",
      "merchant_sort": "ascending alphabetical",
      "priority_key_order": ["critical", "debug", "info", "risk"]
    },
    "flagged_jsonl": {
      "required_fields": ["txn_id", "posted_ms", "priority", "merchant", "note"],
      "sort": "posted_ms descending",
      "priorities_included": ["risk", "critical"],
      "exclude_waived": true,
      "json_format": "compact (no space after colon; use json.dumps separators=(',', ':'))"
    }
  },
  "long_context": {
    "dossier_path": "/app/incident/export_dossier.md",
    "minimum_line_count": 500
  }
}
